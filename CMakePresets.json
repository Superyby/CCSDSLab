{
  "version": 3,
  "configurePresets": [
    {
      "name": "msys2-ucrt64",
      "displayName": "MSYS2 UCRT64 (G++)",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "D:/yby/app/msys264/ucrt64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "D:/yby/app/msys264/ucrt64/bin/g++.exe",
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "environment": {
        "PATH": "D:/yby/app/msys264/ucrt64/bin;$penv{PATH}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "msys2-build",
      "configurePreset": "msys2-ucrt64"
    }
  ]
}
